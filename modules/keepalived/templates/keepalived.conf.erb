# Note: This file is managed by puppet.

global_defs {
}

<%- unless @vips_v4.empty? -%>
vrrp_instance vrrp_ipv4 {
  state <%= @default_state %>
  interface <%= @interface %>
  virtual_router_id <%= @virtual_router_id %>
  priority <%= @priority %>
  advert_int 1
  authentication {
    auth_type PASS
    auth_pass <%= @auth_pass %>
  }
  virtual_ipaddress {
<% @vips_v4.each do |vip| -%>
    <%= vip %>
<% end -%>
  }
  unicast_peer {
<% @peers_v4.each do |peer| -%>
    <%= peer %>
<% end -%>
  }
}
<%- end -%>

<%- unless @vips_v6.empty? -%>
vrrp_instance vrrp_ipv6 {
  state <%= @default_state %>
  interface <%= @interface %>
  virtual_router_id <%= @virtual_router_id %>
  priority <%= @priority %>
  advert_int 1
  authentication {
    auth_type PASS
    auth_pass <%= @auth_pass %>
  }
  virtual_ipaddress {
<% @vips_v6.each do |vip| -%>
    <%= vip %>
<% end -%>
  }
  unicast_peer {
<% @peers_v6.each do |peer| -%>
    <%= peer %>
<% end -%>
  }
}
<%- end -%>
