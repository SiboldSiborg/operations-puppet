<%#- SPDX-License-Identifier: Apache-2.0 -%>
[Unit]
Description=Liberica control plane daemon
After=network-online.target liberica-fp.service liberica-hcforwarder.service liberica-healtcheck.service gobgpd.service

[Install]
WantedBy=multi-user.target

[Service]
User=liberica
CapabilityBoundingSet=
AmbientCapabilities=
SystemCallFilter=~@keyring @clock @cpu-emulation @obsolete @module @raw-io @reboot @swap
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
ProtectSystem=strict
PrivateTmp=yes
ProtectKernelModules=yes
ProtectKernelTunables=yes
ExecStart=/usr/bin/liberica cp
Restart=on-failure
