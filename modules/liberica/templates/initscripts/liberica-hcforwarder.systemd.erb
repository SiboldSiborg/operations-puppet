<%#- SPDX-License-Identifier: Apache-2.0 -%>
[Unit]
Description=Liberica healthcheck forwarder
After=network-online.target

[Install]
WantedBy=multi-user.target

[Service]
User=liberica
CapabilityBoundingSet=CAP_BPF CAP_SYS_ADMIN CAP_NET_ADMIN
AmbientCapabilities=CAP_BPF CAP_SYS_ADMIN CAP_NET_ADMIN
SystemCallFilter=~@keyring @clock @cpu-emulation @obsolete @module @raw-io @reboot @swap
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX AF_NETLINK
ProtectSystem=strict
PrivateTmp=yes
ProtectKernelModules=yes
ProtectKernelTunables=yes
LimitMEMLOCK=infinity
ExecStart=/usr/bin/liberica hcforwarder
Restart=on-failure
