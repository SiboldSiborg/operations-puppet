<%#- SPDX-License-Identifier: Apache-2.0 -%>
extensions:
  health_check:

receivers:
  otlp: # https://github.com/open-telemetry/opentelemetry-collector/blob/main/receiver/otlpreceiver/README.md
    protocols:
      grpc:
        endpoint: "localhost:4317"

processors:
  batch:

  tail_sampling:
    policies: [
      # Thanos sampling -- sample Thanos services at 1% here via otel collector since
      #                    production Thanos version currently predates inbuilt sampling
      {
        name: thanos-sampling,
        type: and,
        and:
          {
            and_sub_policy:
              [
                {
                  # Match thanos service names
                  name: thanos-service-names,
                  type: string_attribute,
                  string_attribute:
                    {
                      key: service.name,
                      values: [
                        thanos-query,
                      ],
                    },
                },
                {
                  # apply probabilistic sampling
                  name: thanos-sampling,
                  type: probabilistic,
                  probabilistic: { sampling_percentage: 1 },
                },
              ],
          },
      },
      # End Thanos sampling
    ]

exporters:
  logging:
  <% if defined?(@otel_gateway_fqdn) %>
  otlp: # https://github.com/open-telemetry/opentelemetry-collector/tree/main/exporter
    endpoint: "<%= @otel_gateway_fqdn %>:<%= @otel_gateway_otlp_port %>"
  <% end %>

service:
  pipelines:
    traces:
      receivers: [otlp]
      processors: [tail_sampling, batch]
      exporters:
        - logging
        <% if defined?(@otel_gateway_fqdn) %>
        - otlp
        <% end %>
  extensions: [health_check]
